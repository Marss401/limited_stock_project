{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",               /* Modern replacement for commonjs */
    "moduleResolution": "Node16",     /* Modern replacement for node */
    "lib": ["ES2022"],
    "types": ["node", "jest"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "prisma/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}